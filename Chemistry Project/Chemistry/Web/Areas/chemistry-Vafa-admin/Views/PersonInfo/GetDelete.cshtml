@using Core.Entities
@model PersonInfo
<div class="main-panel">
    <div class="content-wrapper">
        <div class="row">
            <div class="col-md-12 grid-margin stretch-card">
                <div class="card">
                    <div class="card-body">

                        <p class="card-description">
                            Delete PersonInfo
                        </p>
                        <span>Id: </span>
                        <span>@Model.Id</span>
                        <br>
                        <span>Title: </span>
                        <span>@Model.Title</span>
                    </div>
                    <form method="post" asp-action="deleteasync" asp-controller="personinfo" asp-area="chemistry-vafa-admin" asp-route-id="@Model.Id">
                        <button class="btn btn-dangers">delete</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>